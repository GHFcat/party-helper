/* 右上角入口按钮 */
.rules-entry {
  position: fixed;
  top: calc(20rpx + env(safe-area-inset-top));
  right: 24rpx;
  z-index: 99;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(94, 207, 170, 0.2);
}

.rules-entry-icon {
  font-size: 26rpx;
}

.rules-entry-text {
  font-size: 24rpx;
  color: #5ECFAA;
  font-weight: bold;
}

/* 遮罩层 */
.rules-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

/* 弹窗主体 */
.rules-modal {
  width: 80%;
  max-height: 70vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}

.rules-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(94, 207, 170, 0.2);
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E3A3A;
}

.rules-close {
  font-size: 32rpx;
  color: #9AA5A0;
  padding: 4rpx 12rpx;
}

.rules-body {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 32rpx;
  max-height: 56vh;
}

.rule-line {
  position: relative;
  font-size: 28rpx;
  color: #2E3A3A;
  line-height: 1.6;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  word-break: break-word;
  white-space: normal;
}

.rule-line:last-child {
  margin-bottom: 0;
}

/* ===== 横屏覆盖（十三钗等横屏游戏） ===== */
@media screen and (orientation: landscape) {
  .rules-entry {
    top: calc(12rpx + env(safe-area-inset-top));
    right: 16rpx;
    padding: 5rpx 14rpx;
    border-radius: 24rpx;
    gap: 4rpx;
    box-shadow: 0 2rpx 8rpx rgba(94, 207, 170, 0.2);
  }

  .rules-entry-icon {
    font-size: 16rpx;
  }

  .rules-entry-text {
    font-size: 14rpx;
  }

  .rules-modal {
    width: auto;
    max-width: 70%;
    max-height: 86vh;
    border-radius: 16rpx;
  }

  .rules-header {
    padding: 14rpx 22rpx;
  }

  .rules-title {
    font-size: 20rpx;
  }

  .rules-close {
    font-size: 20rpx;
    padding: 2rpx 8rpx;
  }

  .rules-body {
    padding: 14rpx 22rpx;
    max-height: 72vh;
  }

  .rule-line {
    font-size: 16rpx;
    line-height: 1.5;
    margin-bottom: 8rpx;
    padding-left: 6rpx;
  }
}
