.container {
  padding: 30rpx 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* ===== 信息行 ===== */
.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
  background-color: #fff;
  padding-left: 30rpx;
  padding-right: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.info-label {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* ===== 头像 ===== */
.avatar-wrapper {
  position: relative;
  width: 90rpx;
  height: 90rpx;
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background-color: #eee;
}

/* ===== 昵称输入 ===== */
.nickname-input {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  text-align: right;
  color: #333;
  background: transparent;
  border: none;
  outline: none;
  padding-right: 20rpx;
}

