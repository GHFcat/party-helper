.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin: 32rpx 0;
  color: #2E3A3A;
}

/* 玩家数量 */
.player-count {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin: 24rpx 0 48rpx;
}

.count-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #E6F0EC;
  border-radius: 50%;
  font-size: 40rpx;
  color: #5ECFAA;
}

.count-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #2E3A3A;
}

/* 卡牌背面 */
.card-backs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin: 32rpx 0;
}

.king-card {
  width: 100rpx;
  height: 140rpx;
  background: #F4A261;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-q {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 我的牌 */
.my-card {
  width: 320rpx;
  height: 420rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 48rpx 0;
  border: 4rpx solid rgba(94, 207, 170, 0.15);
  box-shadow: 0 8rpx 32rpx rgba(94, 207, 170, 0.15);
}

.my-card.is-king {
  background: #F4A261;
  border-color: #F7C5D1;
  box-shadow: 0 16rpx 64rpx rgba(244, 162, 97, 0.4);
}

.card-number {
  font-size: 120rpx;
  font-weight: bold;
  color: #5ECFAA;
}

.card-role {
  font-size: 28rpx;
  color: #7A9E8E;
  margin-top: 16rpx;
}

.is-king .card-number {
  color: #fff;
}

.is-king .card-role {
  color: #fff;
}

.waiting-text {
  color: #7A9E8E;
  margin-top: 32rpx;
}

/* 命令表单 */
.command-form {
  width: 100%;
  padding: 0 32rpx;
}

.command-input {
  background: #F3F6F4;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #2E3A3A;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.command-display {
  padding: 48rpx;
  text-align: center;
}

.command-text {
  font-size: 36rpx;
  color: #F4A261;
}
