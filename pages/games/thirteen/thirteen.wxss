.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin: 32rpx 0 8rpx;
  color: #2E3A3A;
}

.subtitle {
  font-size: 28rpx;
  color: #7A9E8E;
  margin-bottom: 32rpx;
}

.hint {
  font-size: 28rpx;
  color: #7A9E8E;
  margin: 16rpx 0;
}

/* 玩家数量 */
.player-count {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin: 24rpx 0 32rpx;
}

.count-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #E6F0EC;
  border-radius: 50%;
  font-size: 40rpx;
  color: #5ECFAA;
}

.count-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #2E3A3A;
}

/* 规则 */
.rules {
  width: 100%;
  margin-bottom: 32rpx;
}

.rule-item {
  display: block;
  font-size: 26rpx;
  color: #7A9E8E;
  line-height: 2;
}

/* 看词 */
.word-card {
  width: 480rpx;
  padding: 48rpx;
  border-radius: 32rpx;
  text-align: center;
  margin: 32rpx 0;
}

.word-card.civilian {
  background: #5ECFAA;
}

.word-card.spy {
  background: #F4A261;
}

.word-text {
  font-size: 56rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  color: #fff;
}

.word-role {
  font-size: 28rpx;
  display: block;
  opacity: 0.85;
  color: #fff;
}

.peek-hint {
  font-size: 24rpx;
  color: #A8BDB4;
  margin-bottom: 32rpx;
}

/* 描述阶段 */
.round-info {
  font-size: 32rpx;
  color: #F4A261;
  font-weight: bold;
  margin: 24rpx 0;
}

.speaker-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx;
  text-align: center;
  width: 80%;
  margin: 24rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(94, 207, 170, 0.12);
}

.speaker-name {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
  color: #2E3A3A;
}

.speaker-hint {
  font-size: 28rpx;
  color: #7A9E8E;
}

.player-status {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  margin: 24rpx 0;
}

.player-dot {
  padding: 8rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #7A9E8E;
  box-shadow: 0 2rpx 8rpx rgba(94, 207, 170, 0.08);
}

.player-dot.eliminated {
  opacity: 0.3;
  text-decoration: line-through;
}

/* 投票 */
.vote-list {
  width: 100%;
  margin: 24rpx 0;
}

.vote-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(94, 207, 170, 0.08);
}

.vote-item.selected {
  border-color: #5ECFAA;
  background: rgba(94, 207, 170, 0.1);
}

.vote-item.eliminated {
  opacity: 0.3;
}

.vote-name {
  font-size: 32rpx;
  color: #2E3A3A;
}

.vote-check {
  color: #5ECFAA;
  font-size: 36rpx;
  font-weight: bold;
}

/* 揭示 */
.eliminated-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
  width: 80%;
  margin: 24rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(94, 207, 170, 0.12);
}

.eliminated-name {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
  color: #2E3A3A;
}

.eliminated-role {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}

.eliminated-role.spy {
  color: #F4A261;
}

.eliminated-role.civilian {
  color: #5ECFAA;
}

.eliminated-word {
  font-size: 28rpx;
  color: #7A9E8E;
  display: block;
}

.word-reveal {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  width: 80%;
  margin: 16rpx 0 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(94, 207, 170, 0.08);
}

.reveal-row {
  display: block;
  font-size: 28rpx;
  color: #7A9E8E;
  margin: 8rpx 0;
}

.reveal-row.spy {
  color: #F4A261;
}
