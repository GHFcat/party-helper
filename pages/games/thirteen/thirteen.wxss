/* ===== 牌桌容器（横屏） ===== */
.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: radial-gradient(ellipse at center, #2D8060 0%, #1E5B3F 100%);
  box-sizing: border-box;
}

/* ===== 左上角退出按钮 ===== */
.nav-exit {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 5rpx 14rpx 5rpx 10rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 24rpx;
  z-index: 20;
}

.nav-exit-icon {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1;
}

.nav-exit-text {
  font-size: 14rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1;
}

/* ===== Mock 调试面板 ===== */
.mock-panel {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 10rpx;
  padding: 8rpx 10rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  z-index: 30;
  max-width: 60%;
}

.mock-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-wrap: wrap;
}

.mock-label {
  font-size: 11rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-right: 2rpx;
}

.mock-btn {
  font-size: 12rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  line-height: 1.3;
}

.mock-btn.is-active {
  background: #F4A261;
  color: #FFFFFF;
  font-weight: bold;
}

.mock-tip {
  font-size: 11rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 2rpx;
}

/* ===== 连接中 ===== */
.connecting {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.connecting-text {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ===== 牌桌 ===== */
.table {
  position: relative;
  width: 100%;
  height: 100%;
}

/* 其他玩家座位 */
.seat {
  position: absolute;
  width: 76rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 房主皇冠（贴在头像正上方） */
.seat-crown {
  font-size: 16rpx;
  line-height: 1;
  margin-bottom: -2rpx;
  filter: drop-shadow(0 1rpx 2rpx rgba(0, 0, 0, 0.5));
}

.seat-avatar {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FFFFFF;
  color: #5ECFAA;
  font-size: 15rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.25);
  overflow: hidden;
}

/* 离线：头像变灰 + 黑色遮罩 + 离线字样 */
.seat-avatar.is-offline,
.self-avatar.is-offline {
  filter: grayscale(1);
  opacity: 0.6;
}

.seat-offline-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.seat-offline-text {
  color: #FFFFFF;
  font-size: 12rpx;
  line-height: 1;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.6);
}

.seat.is-active .seat-avatar {
  border-color: #F4A261;
  box-shadow: 0 0 0 3rpx rgba(244, 162, 97, 0.5), 0 1rpx 4rpx rgba(0, 0, 0, 0.25);
  animation: seatPulse 1.2s ease-in-out infinite;
}

@keyframes seatPulse {
  0%, 100% { box-shadow: 0 0 0 3rpx rgba(244, 162, 97, 0.5), 0 1rpx 4rpx rgba(0, 0, 0, 0.25); }
  50% { box-shadow: 0 0 0 5rpx rgba(244, 162, 97, 0.3), 0 1rpx 4rpx rgba(0, 0, 0, 0.25); }
}

.seat-name {
  font-size: 12rpx;
  color: #FFFFFF;
  margin-top: 2rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.5);
  max-width: 76rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seat-fan {
  display: flex;
  margin-top: 3rpx;
  height: 30rpx;
  align-items: center;
}

.mini-card {
  width: 22rpx;
  height: 30rpx;
  border-radius: 3rpx;
  background: #FFFFFF;
  margin-left: -12rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.15);
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.25);
  box-sizing: border-box;
  position: relative;
}

.mini-card:first-child {
  margin-left: 0;
}

.mini-card.is-red { color: #E74C3C; }
.mini-card.is-black { color: #2C3E50; }

.mini-card-corner {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
}

.mini-card-tl { top: 2rpx; left: 2rpx; }
.mini-card-br { bottom: 2rpx; right: 2rpx; transform: rotate(180deg); }

.mini-card-rank {
  font-size: 9rpx;
  font-weight: bold;
  line-height: 1;
}

.mini-card-suit {
  font-size: 7rpx;
  line-height: 1;
  margin-top: 1rpx;
}

/* ===== 中央牌堆 ===== */
.center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.deck {
  position: relative;
  width: 44rpx;
  height: 60rpx;
}

.deck-card {
  position: absolute;
  width: 44rpx;
  height: 60rpx;
  border-radius: 6rpx;
  background: linear-gradient(135deg, #C0392B, #922B21);
  border: 2rpx solid #FFFFFF;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.deck-bottom { transform: translate(-2rpx, -2rpx); opacity: 0.6; }
.deck-mid { transform: translate(0, 0); opacity: 0.8; }
.deck-top {
  transform: translate(2rpx, 2rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.deck-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

.deck-remaining {
  font-size: 13rpx;
  color: #FFFFFF;
  margin-top: 10rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.4);
}

.deal-btn {
  margin-top: 4rpx;
  background: #F4A261 !important;
  color: #FFFFFF !important;
  font-size: 17rpx;
  font-weight: bold;
  padding: 6rpx 32rpx;
  border-radius: 24rpx;
  line-height: 1.6;
}

.deal-btn::after { border: none; }

.deal-btn[disabled] {
  opacity: 0.5;
  background: #999 !important;
}

.deal-btn.restart-btn {
  background: #5ECFAA !important;
}

.deal-btn.start-game-btn {
  background: #5ECFAA !important;
  padding: 10rpx 56rpx;
  font-size: 20rpx;
}

.deal-btn.start-game-btn[disabled] {
  background: #C8D9D2 !important;
}

.deck-hint {
  font-size: 13rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 10rpx;
}

/* ===== 自己（底部） ===== */
.seat-self {
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 86%;
  max-width: 720rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.self-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 4rpx;
}

.self-avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.self-avatar {
  position: relative;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #FFFFFF;
  color: #5ECFAA;
  font-size: 17rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  overflow: hidden;
}

.self-avatar.is-owner {
  border-color: #F4A261;
}

.self-meta {
  display: flex;
  flex-direction: column;
  margin-bottom: -12rpx;
}

.self-name {
  font-size: 14rpx;
  color: #FFFFFF;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.4);
}

/* ===== 左下角：房间号 ===== */
.room-id-box {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  background: rgba(0, 0, 0, 0.35);
  color: rgba(255, 255, 255, 0.88);
  font-size: 12rpx;
  line-height: 1.2;
  border-radius: 8rpx;
  padding: 6rpx 10rpx;
  z-index: 10;
}

/* ===== 右下角：邀请好友 ===== */
.invite-btn {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  background: #F4A261 !important;
  color: #FFFFFF !important;
  font-size: 13rpx;
  font-weight: bold;
  line-height: 1.4;
  padding: 7rpx 18rpx;
  border-radius: 20rpx;
  margin: 0;
  z-index: 10;
}

.invite-btn::after {
  border: none;
}

.self-hand {
  display: flex;
  justify-content: center;
  flex-wrap: nowrap;
  max-width: 100%;
}

/* 扑克牌（自己手牌正面）—— 堆叠摆放 */
.play-card {
  width: 40rpx;
  height: 56rpx;
  margin-left: -24rpx;
  border-radius: 4rpx;
  background: #FFFFFF;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.35);
  box-sizing: border-box;
  position: relative;
}

.play-card:first-child {
  margin-left: 0;
}

.play-card.is-red { color: #E74C3C; }
.play-card.is-black { color: #2C3E50; }

.card-corner {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1;
}

.card-tl { top: 3rpx; left: 3rpx; }
.card-br { bottom: 3rpx; right: 3rpx; transform: rotate(180deg); }

.card-rank {
  font-size: 12rpx;
  font-weight: bold;
  line-height: 1;
}

.card-suit {
  font-size: 10rpx;
  line-height: 1;
  margin-top: 1rpx;
}

.self-empty {
  color: rgba(255, 255, 255, 0.5);
  font-size: 13rpx;
  padding: 8rpx 0;
}
