<view class="container">
  <rules-modal game-id="{{gameId}}"></rules-modal>

  <!-- 左上角退出按钮（自定义导航栏） -->
  <view class="nav-exit" bindtap="exitRoom">
    <text class="nav-exit-icon">✕</text>
    <text class="nav-exit-text">退出</text>
  </view>

  <!-- ===== 连接中 ===== -->
  <view class="connecting" wx:if="{{phase === 'connecting'}}">
    <text class="connecting-text">正在创建房间…</text>
  </view>

  <!-- ===== 牌桌（等待玩家 + 对局进行中） ===== -->
  <view class="table" wx:if="{{phase === 'table'}}">
    <!-- 其他玩家（围绕牌桌） -->
    <view
      class="seat {{nextUserId === p.userId ? 'is-active' : ''}}"
      wx:for="{{otherPlayers}}"
      wx:for-item="p"
      wx:key="userId"
      style="{{p.positionStyle}}"
    >
      <view class="seat-avatar">{{p.userName[0] || '?'}}</view>
      <text class="seat-name">{{p.userName}}{{p.isOwner ? ' 👑' : ''}}</text>
      <view class="seat-fan">
        <view class="card-back" wx:for="{{p.displayCount}}" wx:for-item="c" wx:key="*this"></view>
      </view>
      <text class="seat-count">{{p.cardCount}}张</text>
    </view>

    <!-- 中央：未开始显示「开始游戏」/ 等待文案；已开始显示牌堆 + 发牌按钮 -->
    <view class="center">
      <block wx:if="{{gameStarted}}">
        <view class="deck">
          <view class="deck-card deck-bottom"></view>
          <view class="deck-card deck-mid"></view>
          <view class="deck-card deck-top">
            <text class="deck-label">🂠</text>
          </view>
        </view>
        <text class="deck-remaining">剩余 {{remaining}} / {{totalCards}}</text>
        <block wx:if="{{isHost}}">
          <button class="deal-btn" wx:if="{{remaining > 0}}" bindtap="dealCard">发 牌</button>
          <button class="deal-btn restart-btn" wx:else bindtap="restartGame">再开一局</button>
        </block>
        <text class="deck-hint" wx:else>{{remaining === 0 ? '本局已结束' : '等待房主发牌'}}</text>
      </block>

      <block wx:else>
        <button
          wx:if="{{isHost}}"
          class="deal-btn start-game-btn"
          bindtap="startGame"
          disabled="{{players.length < minPlayers}}">
          开始游戏
        </button>
        <text class="deck-hint" wx:else>等待房主开始游戏…</text>
      </block>
    </view>

    <!-- 自己（底部） -->
    <view class="seat-self" wx:if="{{selfPlayer}}">
      <view class="self-header">
        <view class="self-avatar {{selfPlayer.isOwner ? 'is-owner' : ''}}">{{selfPlayer.userName[0] || '?'}}</view>
        <view class="self-meta">
          <text class="self-name">{{selfPlayer.userName}}（我）{{selfPlayer.isOwner ? '👑' : ''}}</text>
          <view class="self-sub">
            <text class="self-count" bindtap="copyRoomId">手牌 {{selfPlayer.cardCount}} 张 · 房间 {{roomId}}</text>
            <button class="self-invite-btn" open-type="share">📤</button>
          </view>
        </view>
      </view>
      <view class="self-hand">
        <view class="play-card {{c.isRed ? 'is-red' : 'is-black'}}" wx:for="{{selfPlayer.hand}}" wx:for-item="c" wx:key="id">
          <text class="play-card-rank">{{c.rankLabel}}</text>
          <text class="play-card-suit">{{c.suitSymbol}}</text>
        </view>
        <view class="self-empty" wx:if="{{selfPlayer.cardCount === 0}}">还没有牌</view>
      </view>
    </view>
  </view>
</view>
