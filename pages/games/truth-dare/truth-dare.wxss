.container {
  padding: 30rpx;
  padding-top: 80rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hint-text {
  font-size: 36rpx;
  color: #7A9E8E;
}

/* 各阶段容器：占满剩余空间并垂直居中卡片 */
.choose-phase,
.reveal-phase {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
}

/* 卡片背面 */
.card-back {
  width: 360rpx;
  height: 480rpx;
  background: #5ECFAA;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 64rpx rgba(94, 207, 170, 0.35);
}

.card-back:active {
  transform: scale(0.95);
}

.card-back-text {
  font-size: 120rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 选择卡片 */
.choose-cards {
  display: flex;
  gap: 32rpx;
}

.choose-card {
  width: 280rpx;
  height: 360rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.choose-card:active {
  transform: scale(0.95);
}

.choose-card.truth {
  background: #5ECFAA;
  box-shadow: 0 16rpx 48rpx rgba(94, 207, 170, 0.35);
}

.choose-card.dare {
  background: #F4A261;
  box-shadow: 0 16rpx 48rpx rgba(244, 162, 97, 0.35);
}

.choose-label {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.choose-icon {
  font-size: 72rpx;
}

/* 结果 */
.result-card {
  width: 600rpx;
  min-height: 400rpx;
  border-radius: 32rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.result-card.truth {
  background: #5ECFAA;
}

.result-card.dare {
  background: #F4A261;
}

.result-type {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 32rpx;
  color: #fff;
}

.result-content {
  font-size: 34rpx;
  line-height: 1.8;
  text-align: center;
  color: #fff;
}

.next-btn {
  margin-top: 48rpx;
  width: 400rpx;
}
