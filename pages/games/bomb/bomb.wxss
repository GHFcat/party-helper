.container {
  padding: 30rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 48rpx;
  color: #2E3A3A;
}

/* 时间设置 */
.time-setting {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  width: 100%;
  text-align: center;
  margin-bottom: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(94, 207, 170, 0.12);
}

.setting-label {
  font-size: 28rpx;
  color: #7A9E8E;
  display: block;
  margin-bottom: 24rpx;
}

.time-control {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.time-btn {
  padding: 12rpx 24rpx;
  background: #E6F0EC;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #5ECFAA;
}

.time-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #F4A261;
}

.setting-hint {
  font-size: 24rpx;
  color: #A8BDB4;
  display: block;
  margin-top: 16rpx;
}

.start-btn {
  width: 400rpx;
}

/* 倒计时 */
.bomb-display {
  text-align: center;
  margin: 32rpx 0;
}

.bomb-icon {
  font-size: 120rpx;
  display: block;
  animation: pulse 0.5s infinite alternate;
}

.bomb-display.urgent .bomb-icon {
  animation: urgentPulse 0.3s infinite alternate;
}

@keyframes pulse {
  from { transform: scale(1); }
  to { transform: scale(1.1); }
}

@keyframes urgentPulse {
  from { transform: scale(1); }
  to { transform: scale(1.2); }
}

.countdown {
  font-size: 96rpx;
  font-weight: bold;
  color: #F4A261;
  display: block;
  margin-top: 16rpx;
}

.bomb-display.urgent .countdown {
  color: #E76F51;
}

.holder-text {
  font-size: 32rpx;
  color: #7A9E8E;
  margin: 24rpx 0;
}

.progress-bar {
  width: 80%;
  height: 16rpx;
  background: #E6F0EC;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 32rpx 0;
}

.progress-fill {
  height: 100%;
  background: #F4A261;
  border-radius: 8rpx;
  transition: width 1s linear;
}

.pass-btn {
  width: 500rpx;
  margin-top: 48rpx;
}

/* 爆炸 */
.explosion-effect {
  text-align: center;
  animation: boom 0.5s ease-out;
}

@keyframes boom {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); opacity: 1; }
}

.explosion-icon {
  font-size: 160rpx;
  display: block;
}

.explosion-text {
  font-size: 64rpx;
  font-weight: bold;
  color: #F4A261;
  display: block;
  margin-top: 16rpx;
}

.loser-text {
  font-size: 40rpx;
  color: #F4A261;
  font-weight: bold;
  margin: 32rpx 0 8rpx;
}

.punishment {
  font-size: 32rpx;
  color: #7A9E8E;
  margin-bottom: 48rpx;
}
