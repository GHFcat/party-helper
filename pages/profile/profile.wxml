<view class="container">

  <view class="profile-section" wx:if="{{userInfo}}">
    <view class="profile-header">
      <image class="avatar" src="{{userInfo.avatar}}" bindtap="setUserInfo" mode="aspectFill" />
      <text class="nickname">{{userInfo.nickName}}</text>
    </view>

    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{stats.totalGames}}</text>
        <text class="stat-label">总场数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.totalPunishments}}</text>
        <text class="stat-label">被罚次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.winRate}}%</text>
        <text class="stat-label">胜率</text>
      </view>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="">
        <text>游戏记录</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item" bindtap="">
        <text>排行榜</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item" bindtap="">
        <text>意见反馈</text>
        <text class="arrow">></text>
      </view>
      <view class="menu-item" bindtap="">
        <text>关于我们</text>
        <text class="arrow">></text>
      </view>
    </view>

    <button class="btn-primary logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
