.container {
  padding: 30rpx;
  min-height: 100vh;
}

/* 未登录 */
.login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.default-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #E6F0EC;
  margin-bottom: 48rpx;
}

.login-section .btn-primary {
  width: 320rpx;
}

/* 头像 */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #5ECFAA;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 16rpx;
  color: #2E3A3A;
}

/* 统计 */
.stats-grid {
  display: flex;
  justify-content: space-around;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(94, 207, 170, 0.12);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #5ECFAA;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #7A9E8E;
  display: block;
  margin-top: 4rpx;
}

/* 菜单 */
.menu-list {
  margin-top: 24rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  font-size: 30rpx;
  color: #2E3A3A;
  box-shadow: 0 2rpx 12rpx rgba(94, 207, 170, 0.08);
}

.arrow {
  color: #A8BDB4;
}

.logout-btn {
  margin-top: 48rpx;
  width: 100%;
}
