<view class="container">
  <!-- 输入房间号加入（尚未进入任何房间时显示） -->
  <view class="join-section" wx:if="{{!roomId}}">
    <view class="card">
      <text class="title">加入房间</text>
      <input
        class="code-input"
        type="number"
        placeholder="请输入房间号"
        value="{{inputRoomId}}"
        bindinput="onCodeInput"
      />
      <button class="btn-primary" bindtap="joinByCode">加入</button>
    </view>
  </view>

  <!-- 房间详情 -->
  <view class="room-section" wx:if="{{roomId}}">
    <!-- 房间号 -->
    <view class="room-code-section">
      <text class="room-label">房间号</text>
      <view class="room-code" bindtap="copyRoomId">
        <text class="code-text">{{roomId}}</text>
        <text class="copy-tip">点击复制</text>
      </view>
      <button class="btn-primary share-btn" open-type="share">
        邀请好友
      </button>
    </view>

    <!-- 玩家列表 -->
    <view class="players-section">
      <text class="section-title">玩家 ({{players.length}}/{{maxPlayers}})</text>
      <view class="player-list">
        <view class="player-item" wx:for="{{players}}" wx:key="userId">
          <view class="player-avatar player-avatar-fallback">{{item.userName[0]}}</view>
          <view class="player-meta">
            <text class="player-name">{{item.userName}}{{item.isSelf ? '（我）' : ''}}</text>
            <text class="player-tag">{{item.isOwner ? '房主' : '已加入'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section">
      <button
        class="btn-primary start-btn"
        wx:if="{{isHost}}"
        bindtap="startGame"
        disabled="{{players.length < minPlayers}}"
      >
        开始游戏（需{{minPlayers}}人）
      </button>
      <view class="waiting-tip" wx:else>等待房主开始游戏…</view>
    </view>
  </view>
</view>
