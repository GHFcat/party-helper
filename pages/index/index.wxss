.container {
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* 顶部 */
.header {
  margin-bottom: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #5ECFAA;
}

.user-text {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #2E3A3A;
}

.greeting {
  font-size: 26rpx;
  color: #7A9E8E;
  margin-top: 4rpx;
}

/* 分类导航 */
.category-bar {
  white-space: nowrap;
  margin-bottom: 30rpx;
  padding-bottom: 4rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #7A9E8E;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(94, 207, 170, 0.08);
  transition: all 0.2s;
}

.category-item.active {
  color: #ffffff;
  background: #5ECFAA;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(94, 207, 170, 0.3);
}

/* 游戏列表 - 2列网格 */
.game-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.game-card {
  width: 335rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(94, 207, 170, 0.1);
  box-sizing: border-box;
  transition: transform 0.2s;
  overflow: hidden;
}

/* 热门游戏占满整行 */
.game-card-hot {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.game-card:active {
  transform: scale(0.97);
}

/* 封面 */
.game-cover-wrap {
  position: relative;
  width: 100%;
  height: 200rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #E6F0EC;
}

.game-card-hot .game-cover-wrap {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 0;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.game-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.game-icon-text {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E6F0EC;
  font-size: 60rpx;
  font-weight: bold;
  color: #5ECFAA;
}

.game-card-hot .game-icon-text {
  font-size: 48rpx;
}

.hot-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background: #F4A261;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 0 12rpx 0 12rpx;
}

/* 信息 */
.game-info {
  display: flex;
  flex-direction: column;
}

.game-card-hot .game-info {
  flex: 1;
  overflow: hidden;
}

.game-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #2E3A3A;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-desc {
  font-size: 22rpx;
  color: #7A9E8E;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.game-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.game-players,
.game-duration {
  font-size: 20rpx;
  color: #7A9E8E;
}

.game-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.game-tag {
  display: inline-block;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
  color: #fff;
  height: 30rpx;
  line-height: 30rpx;
}

/* 加载中 */
.loading-box {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  color: #7A9E8E;
  font-size: 28rpx;
}

/* 空状态 */
.empty-box {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #7A9E8E;
  font-size: 28rpx;
}

/* 快速开始 */
.quick-start {
  position: fixed;
  bottom: 60rpx;
  left: 30rpx;
  right: 30rpx;
}

.quick-btn {
  font-size: 34rpx;
}
